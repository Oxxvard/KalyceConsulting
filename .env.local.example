# Resend (newsletter) — copiez ce fichier en .env.local et remplissez les valeurs.
# 1. Créez un compte sur https://resend.com
# 2. Générez une clé API : https://resend.com/api-keys
# 3. Créez une Audience : https://resend.com/audiences, puis récupérez son ID
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
